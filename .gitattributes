# Normalize line endings: store text as LF, check out as-is (LF) on every OS.
* text=auto eol=lf

# Windows-only scripts must keep CRLF so PowerShell/cmd run correctly.
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.cmd   text eol=crlf
*.bat   text eol=crlf

# Source files (explicit LF)
*.rs    text eol=lf
*.toml  text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary assets (never normalize / diff)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.icns  binary
*.webp  binary
*.exe   binary
*.dll   binary
*.so    binary
*.dylib binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary

# Generated lockfiles: collapse diffs and mark as generated in language stats.
pnpm-lock.yaml  -diff linguist-generated
Cargo.lock      -diff linguist-generated
