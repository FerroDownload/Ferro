{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "opener:default",
    "notification:default",
    "dialog:allow-open",
    "deep-link:default",
    "autostart:allow-enable",
    "autostart:allow-disable"
  ]
}
